# xAI / Grok (OpenAI-compatible endpoint)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-3-mini

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=social-media-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Google OAuth2 + YouTube
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/social_media_agent
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:password@db:5432/social_media_agent

# Redis
REDIS_URL=redis://redis:6379/0

# App
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
WHISPER_MODEL_SIZE=base
FRONTEND_URL=http://localhost:5173
MAX_UPLOAD_SIZE_GB=2
